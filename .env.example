APP_NAME="Legal Aid Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Tbilisi
APP_URL=http://localhost:8000

APP_LOCALE=ka
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ka_GE
INSTALLER_ENABLED=true

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=legalaid
DB_USERNAME=root
DB_PASSWORD=

# Optional defaults for the packaged first-run installer.
# These are copied into the Hostinger package so /install opens with
# the right database values already filled in.
DEPLOY_DB_HOST=
DEPLOY_DB_PORT=3306
DEPLOY_DB_DATABASE=
DEPLOY_DB_USERNAME=
DEPLOY_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@legalaid.ge"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# CORS - Allow React frontend
FRONTEND_URL=http://localhost:5173
FRONTEND_PROD_URL=https://legalaid.ge

# Image Processing
IMAGE_THUMBNAIL_WIDTH=400
IMAGE_THUMBNAIL_HEIGHT=280
IMAGE_POPUP_WIDTH=800
IMAGE_POPUP_HEIGHT=500
IMAGE_SINGLE_WIDTH=1200
IMAGE_SINGLE_HEIGHT=750
IMAGE_QUALITY=82
